<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="700" prefWidth="920" style="-fx-background-color: #F2F4EE;" xmlns="http://javafx.com/javafx/21.0.5" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.proyecto_pastoral.Controller.FichaCompletaController">

    <ScrollPane fitToWidth="true" style="-fx-background: #F2F4EE; -fx-background-color: #F2F4EE;" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <VBox spacing="0">

            <!-- CABECERA -->
            <VBox alignment="CENTER" spacing="3" style="-fx-background-color: #3D4A20; -fx-padding: 16 32 14 32;">
                <HBox alignment="CENTER" spacing="14">
                    <Label style="-fx-font-size: 22px; -fx-text-fill: #C8D4A0;" text="✟" />
                    <VBox alignment="CENTER_LEFT">
                        <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #F5F0E8;" text="PASTORAL SOCIAL — DIÓCESIS DE CARTAGO" />
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #A8B880; -fx-letter-spacing: 1;" text="FICHA DE REGISTRO DE PARTICIPANTES" />
                    </VBox>
                </HBox>
            </VBox>

            <VBox spacing="14" style="-fx-padding: 18 26;">

                <!-- SECCIÓN 1: DATOS DEL REGISTRO -->
                <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 16 20; -fx-effect: dropshadow(gaussian,rgba(61,74,32,0.08),8,0,0,2);">
                    <HBox><Label style="-fx-background-color: #5D682D; -fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: bold; -fx-background-radius: 4; -fx-padding: 3 10;" text="DATOS DEL REGISTRO" /></HBox>
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <VBox alignment="CENTER" minWidth="90" style="-fx-background-color: #3D4A20; -fx-background-radius: 8; -fx-padding: 10 16;">
                            <Label style="-fx-font-size: 8px; -fx-text-fill: #A8B880;" text="FICHA N°" />
                            <Label fx:id="lblNumeroFicha" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;" text="---" />
                        </VBox>
                        <VBox spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="24">
                                <VBox spacing="3">
                                    <Label style="-fx-font-size: 10px; -fx-text-fill: #7A8A5A;" text="Fecha de inicio" />
                                    <Label fx:id="lblFechaInicio" style="-fx-font-weight: bold; -fx-text-fill: #5D682D; -fx-font-size: 13px;" text="--/--/----" />
                                </VBox>
                                <VBox spacing="3">
                                    <Label style="-fx-font-size: 10px; -fx-text-fill: #7A8A5A;" text="Fecha prevista de conclusión" />
                                    <Label fx:id="lblFechaConclusion" style="-fx-font-weight: bold; -fx-text-fill: #5D682D; -fx-font-size: 13px;" text="--/--/----" />
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>
                    <VBox spacing="4">
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #7A8A5A;" text="Observaciones" />
                        <TextArea fx:id="txtObservaciones" prefRowCount="3" wrapText="true" editable="false" style="-fx-font-size: 11px; -fx-control-inner-background: #F9F9F9; -fx-border-color: #E0E0E0;" />
                    </VBox>
                </VBox>

                <!-- SECCIÓN 2: DATOS PARROQUIALES -->
                <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 16 20; -fx-effect: dropshadow(gaussian,rgba(61,74,32,0.08),8,0,0,2);">
                    <HBox><Label style="-fx-background-color: #5D682D; -fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: bold; -fx-background-radius: 4; -fx-padding: 3 10;" text="DATOS PARROQUIALES" /></HBox>
                    <HBox spacing="20">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: #7A8A5A;" text="Parroquia" />
                            <Label fx:id="lblParroquia" style="-fx-font-weight: bold; -fx-text-fill: #2C3527;" text="---" />
                        </VBox>
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: #7A8A5A;" text="Sector" />
                            <Label fx:id="lblSector" style="-fx-font-weight: bold; -fx-text-fill: #2C3527;" text="---" />
                        </VBox>
                    </HBox>

                </VBox>

                <!-- SECCIÓN 3: PERSONAS -->
                <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 16 20; -fx-effect: dropshadow(gaussian,rgba(61,74,32,0.08),8,0,0,2);">
                    <HBox><Label style="-fx-background-color: #5D682D; -fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: bold; -fx-background-radius: 4; -fx-padding: 3 10;" text="PERSONAS PARTICIPANTES" /></HBox>
                    <VBox spacing="8" style="-fx-border-color: #E5E5E5; -fx-border-width: 1 0 0 0; -fx-padding: 10 0 0 0;">
                        <Label style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #5D682D;" text="PERSONA A" />
                        <GridPane hgap="10" vgap="5">
                            <Label style="-fx-font-size: 9px; -fx-text-fill: #7A8A5A;" text="Nombre" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <Label fx:id="lblNombreA" style="-fx-font-weight: bold; -fx-text-fill: #2C3527;" text="---" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                            <Label style="-fx-font-size: 9px; -fx-text-fill: #7A8A5A;" text="Documento" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                            <Label fx:id="lblDocA" style="-fx-font-weight: bold; -fx-text-fill: #2C3527;" text="---" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                            <Label style="-fx-font-size: 9px; -fx-text-fill: #7A8A5A;" text="Sexo" GridPane.columnIndex="4" GridPane.rowIndex="0" />
                            <Label fx:id="lblSexoA" style="-fx-font-weight: bold; -fx-text-fill: #2C3527;" text="---" GridPane.columnIndex="5" GridPane.rowIndex="0" />
                            <Label style="-fx-font-size: 9px; -fx-text-fill: #7A8A5A;" text="Jefatura" GridPane.columnIndex="6" GridPane.rowIndex="0" />
                            <Label fx:id="lblJefaturaA" style="-fx-font-weight: bold; -fx-text-fill: #2C3527;" text="---" GridPane.columnIndex="7" GridPane.rowIndex="0" />
                        </GridPane>
                    </VBox>
                    <VBox spacing="8" style="-fx-border-color: #E5E5E5; -fx-border-width: 1 0 0 0; -fx-padding: 10 0 0 0;">
                        <Label style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #5D682D;" text="PERSONA B" />
                        <GridPane hgap="10" vgap="5">
                            <Label style="-fx-font-size: 9px; -fx-text-fill: #7A8A5A;" text="Nombre" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <Label fx:id="lblNombreB" style="-fx-font-weight: bold; -fx-text-fill: #2C3527;" text="---" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                            <Label style="-fx-font-size: 9px; -fx-text-fill: #7A8A5A;" text="Documento" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                            <Label fx:id="lblDocB" style="-fx-font-weight: bold; -fx-text-fill: #2C3527;" text="---" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                            <Label style="-fx-font-size: 9px; -fx-text-fill: #7A8A5A;" text="Sexo" GridPane.columnIndex="4" GridPane.rowIndex="0" />
                            <Label fx:id="lblSexoB" style="-fx-font-weight: bold; -fx-text-fill: #2C3527;" text="---" GridPane.columnIndex="5" GridPane.rowIndex="0" />
                            <Label style="-fx-font-size: 9px; -fx-text-fill: #7A8A5A;" text="Jefatura" GridPane.columnIndex="6" GridPane.rowIndex="0" />
                            <Label fx:id="lblJefaturaB" style="-fx-font-weight: bold; -fx-text-fill: #2C3527;" text="---" GridPane.columnIndex="7" GridPane.rowIndex="0" />
                        </GridPane>
                    </VBox>
                    <VBox spacing="8" style="-fx-border-color: #E5E5E5; -fx-border-width: 1 0 0 0; -fx-padding: 10 0 0 0;">
                        <Label style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #5D682D;" text="PERSONA C" />
                        <GridPane hgap="10" vgap="5">
                            <Label style="-fx-font-size: 9px; -fx-text-fill: #7A8A5A;" text="Nombre" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <Label fx:id="lblNombreC" style="-fx-font-weight: bold; -fx-text-fill: #2C3527;" text="---" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                            <Label style="-fx-font-size: 9px; -fx-text-fill: #7A8A5A;" text="Documento" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                            <Label fx:id="lblDocC" style="-fx-font-weight: bold; -fx-text-fill: #2C3527;" text="---" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                            <Label style="-fx-font-size: 9px; -fx-text-fill: #7A8A5A;" text="Sexo" GridPane.columnIndex="4" GridPane.rowIndex="0" />
                            <Label fx:id="lblSexoC" style="-fx-font-weight: bold; -fx-text-fill: #2C3527;" text="---" GridPane.columnIndex="5" GridPane.rowIndex="0" />
                            <Label style="-fx-font-size: 9px; -fx-text-fill: #7A8A5A;" text="Jefatura" GridPane.columnIndex="6" GridPane.rowIndex="0" />
                            <Label fx:id="lblJefaturaC" style="-fx-font-weight: bold; -fx-text-fill: #2C3527;" text="---" GridPane.columnIndex="7" GridPane.rowIndex="0" />
                        </GridPane>
                    </VBox>
                </VBox>

                <!-- SECCIÓN 4: VIVIENDA -->
                <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 16 20; -fx-effect: dropshadow(gaussian,rgba(61,74,32,0.08),8,0,0,2);">
                    <HBox><Label style="-fx-background-color: #5D682D; -fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: bold; -fx-background-radius: 4; -fx-padding: 3 10;" text="VIVIENDA" /></HBox>
                    <GridPane hgap="20" vgap="10">
                        <VBox spacing="4">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: #7A8A5A;" text="Tipo de vivienda" />
                            <Label fx:id="lblTipoVivienda" style="-fx-font-weight: bold; -fx-text-fill: #2C3527;" text="---" />
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="1">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: #7A8A5A;" text="Tenencia" />
                            <Label fx:id="lblTenencia" style="-fx-font-weight: bold; -fx-text-fill: #2C3527;" text="---" />
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="2">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: #7A8A5A;" text="Condición" />
                            <Label fx:id="lblCondicion" style="-fx-font-weight: bold; -fx-text-fill: #2C3527;" text="---" />
                        </VBox>
                    </GridPane>
                    <HBox spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #7A8A5A;" text="Dirección" />
                        <TextArea fx:id="txtDireccion" prefRowCount="2" wrapText="true" editable="false" style="-fx-font-size: 11px; -fx-control-inner-background: #F9F9F9; -fx-border-color: #E0E0E0;" />
                    </VBox>
                    <VBox minWidth="170" spacing="4">
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #7A8A5A;" text="Teléfonos de contacto" />
                        <Label fx:id="lblTelefono" style="-fx-font-weight: bold; -fx-text-fill: #2C3527;" text="---" />
                    </VBox>
                </HBox>
                </VBox>



            </VBox>
        </VBox>
    </ScrollPane>
</AnchorPane>
