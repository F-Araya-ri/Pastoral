<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            styleClass="scroll-pane"
            stylesheets="@../../../../formulario-pastoral.css"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="main.proyecto_pastoral.Controller.ControllersRegistro.Paso3Controller">
   <content>
      <VBox styleClass="form-root" spacing="20">

         <VBox spacing="4">
            <Label styleClass="section-title" text="Personas del hogar" />
            <Label styleClass="section-subtitle" text="Registre a cada integrante del núcleo familiar" />
            <Separator />
         </VBox>


         <VBox styleClass="card" spacing="14">


            <HBox spacing="14">
               <VBox spacing="4" HBox.hgrow="ALWAYS">
                  <Label styleClass="field-label" text="Nombre" />
                  <TextField fx:id="txtNombre"
                             styleClass="text-field"
                             promptText="Nombre" />
               </VBox>

               <VBox spacing="4" HBox.hgrow="ALWAYS">
                  <Label styleClass="field-label" text="Primer apellido" />
                  <TextField fx:id="txtprimerApellido"
                             styleClass="text-field"
                             promptText="Primer apellido" />
               </VBox>
               <VBox spacing="4" HBox.hgrow="ALWAYS">
                  <Label styleClass="field-label" text="Segundo apellido" />
                  <TextField fx:id="txtsegundoApellido"
                             styleClass="text-field"
                             promptText="Segundo apellido" />
               </VBox>

            </HBox>


            <HBox spacing="14">
               <VBox spacing="4" prefWidth="130">
                  <Label styleClass="field-label" text="Tipo de documento" />
                  <ComboBox fx:id="cmbTipoDoc"
                            styleClass="combo-box"
                            prefWidth="130"
                            promptText="Tipo" />
               </VBox>
               <VBox spacing="4" prefWidth="140">
                  <Label styleClass="field-label" text="N° de documento" />
                  <TextField fx:id="txtDocumento"
                             styleClass="text-field"
                             prefWidth="140"
                             promptText="Número" />
               </VBox>
               <VBox spacing="4" prefWidth="100">
                  <Label styleClass="field-label" text="Sexo" />
                  <ComboBox fx:id="cmbSexo"
                            styleClass="combo-box"
                            prefWidth="100" />
               </VBox>
               <VBox spacing="4" prefWidth="80">
                  <Label styleClass="field-label" text="Edad" />
                  <TextField fx:id="txtEdad"
                             styleClass="text-field"
                             prefWidth="80"
                             promptText="Años" />
               </VBox>

               <VBox spacing="4" prefWidth="200">
                  <Label styleClass="field-label" text="Numero de Telefono" />
                  <TextField fx:id="txtTelfono"
                             styleClass="text-field"
                             prefWidth="80"
                             promptText="Numero de Telefono" />
               </VBox>
            </HBox>


            <HBox spacing="14" alignment="CENTER_LEFT">
               <VBox spacing="4" HBox.hgrow="ALWAYS">
                  <Label styleClass="field-label" text="Relación con el jefe/a de familia" />
                  <ComboBox fx:id="cmbRelacion"
                            styleClass="combo-box"
                            maxWidth="Infinity"
                            promptText="Seleccione relación" />
               </VBox>
               <VBox spacing="4" prefWidth="180" alignment="BOTTOM_LEFT">
                  <Label styleClass="field-label" text="Jefatura del hogar" />
                  <CheckBox fx:id="chkJefatura"
                            styleClass="check-box"
                            text="Es jefe/a de familia" />
               </VBox>
            </HBox>
         </VBox>


         <VBox styleClass="card" spacing="14">
            <Label styleClass="field-label"
                   style="-fx-font-size: 13px; -fx-text-fill: -color-primary-mid;"
                   text="Contexto social" />

            <HBox spacing="14">
               <VBox spacing="4" HBox.hgrow="ALWAYS">
                  <Label styleClass="field-label" text="País de origen" />
                  <TextField fx:id="txtPais"
                             styleClass="text-field"
                             promptText="País" />
               </VBox>
               <VBox spacing="4" HBox.hgrow="ALWAYS">
                  <Label styleClass="field-label" text="Estado migratorio" />
                  <ComboBox fx:id="cmbMigracion"
                            styleClass="combo-box"
                            maxWidth="Infinity"
                            promptText="Seleccione..." />
               </VBox>
               <VBox spacing="4" HBox.hgrow="ALWAYS">
                  <Label styleClass="field-label" text="Nivel educativo" />
                  <ComboBox fx:id="cmbEducacion"
                            styleClass="combo-box"
                            maxWidth="Infinity"
                            promptText="Seleccione..." />
               </VBox>
               <VBox spacing="4" HBox.hgrow="ALWAYS">
                  <Label styleClass="field-label" text="Condición de salud" />
                  <ComboBox fx:id="cmbSalud"
                            styleClass="combo-box"
                            maxWidth="Infinity"
                            promptText="Seleccione..." />
               </VBox>
               <VBox spacing="4" HBox.hgrow="ALWAYS">
                  <Label styleClass="field-label" text="Tipo de seguro" />
                  <ComboBox fx:id="cmbSeguro"
                            styleClass="combo-box"
                            maxWidth="Infinity"
                            promptText="Seleccione..." />
               </VBox>
            </HBox>
         </VBox>

         <TitledPane collapsible="false"
                     styleClass="titled-pane"
                     text="💼  Ingreso familiar">
            <HBox spacing="14">
               <VBox spacing="4" HBox.hgrow="ALWAYS">
                  <Label styleClass="field-label" text="Ocupación / Pensión" />
                  <TextField fx:id="txtOcupacion"
                             styleClass="text-field"
                             promptText="Ocupación o pensión" />
               </VBox>
               <VBox spacing="4" prefWidth="140" alignment="BOTTOM_LEFT">
                  <Label styleClass="field-label" text="Situación laboral" />
                  <CheckBox fx:id="chkTrabaja"
                            styleClass="check-box"
                            text="Sí trabaja actualmente" />
               </VBox>
               <VBox spacing="4" HBox.hgrow="ALWAYS">
                  <Label styleClass="field-label" text="Ingreso mensual aproximado" />
                  <TextField fx:id="txtIngreso"
                             styleClass="text-field"
                             promptText="₡ 0.00" />
               </VBox>
            </HBox>
         </TitledPane>

         <!-- ══ Botón agregar ══════════════════════════════════════ -->
         <HBox alignment="CENTER_LEFT">
            <Button onAction="#agregarPersona"
                    styleClass="btn-primary"
                    text="＋  Agregar persona al hogar" />
         </HBox>

         <!-- ══ Tabla de personas ══════════════════════════════════ -->
         <VBox spacing="8">
            <Label styleClass="field-label"
                   style="-fx-font-size: 13px; -fx-text-fill: -color-primary-mid;"
                   text="Personas registradas en el hogar" />

            <TableView fx:id="tablaPersonas"
                       styleClass="table-view"
                       prefHeight="180">
               <columns>
                  <TableColumn fx:id="colNombre"   prefWidth="210" text="Nombre completo" />
                  <TableColumn fx:id="colDocumento" prefWidth="120" text="Cédula / Doc." />
                  <TableColumn fx:id="colSexo"      prefWidth="65"  text="Sexo" />
                  <TableColumn fx:id="colEdad"      prefWidth="55"  text="Edad" />
                  <TableColumn fx:id="colJefatura"  prefWidth="80"  text="Jefatura" />
                  <TableColumn fx:id="colRelacion"  prefWidth="120" text="Relación" />
               </columns>
               <placeholder>
                  <Label styleClass="msg-success"
                         text="Aún no se han agregado personas al hogar." />
               </placeholder>
            </TableView>
         </VBox>

      </VBox>
   </content>
</ScrollPane>
